{
  "name": "nobodywho",
  "version": "0.1.0",
  "description": "Run LLMs locally with offline inference — Node.js bindings",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "nobodywho",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nobodywho-ooo/nobodywho"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "build": "napi build --release",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish",
    "version": "napi version"
  },
  "optionalDependencies": {
    "nobodywho-darwin-x64": "0.1.0",
    "nobodywho-darwin-arm64": "0.1.0",
    "nobodywho-linux-x64-gnu": "0.1.0",
    "nobodywho-linux-arm64-gnu": "0.1.0",
    "nobodywho-win32-x64-msvc": "0.1.0"
  }
}