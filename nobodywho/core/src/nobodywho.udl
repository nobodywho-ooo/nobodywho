namespace nobodywho {
    // Initialize llama.cpp logging
    void init_logging();

    // Load a model from a GGUF file
    [Throws=NobodyWhoError]
    Model load_model(string path, boolean use_gpu);
};

// Main error type
[Error]
enum NobodyWhoError {
    "ModelNotFound",
    "InvalidModel",
    "InitializationError",
    "InferenceError",
    "Other",
};

// Message role in chat
enum Role {
    "User",
    "Assistant",
    "System",
    "Tool",
};

// Chat message
dictionary Message {
    Role role;
    string content;
};

// LLM Model
interface Model {
    // Get model path
    string path();
};

// Chat configuration
dictionary ChatConfig {
    u32 context_size;
    string? system_prompt;
};

// Chat interface
interface Chat {
    // Create a new chat session
    [Throws=NobodyWhoError]
    constructor(Model model, ChatConfig config);

    // Ask a question and get a blocking response
    [Throws=NobodyWhoError]
    string ask_blocking(string prompt);

    // Get chat history
    [Throws=NobodyWhoError]
    sequence<Message> history();
};
