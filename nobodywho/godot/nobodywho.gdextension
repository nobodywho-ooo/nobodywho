[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.5
reloadable = true

# Per-target subdirectory: the ggml/llama libs (dynamic-link feature) have generic
# filenames (libggml.so, ...) that would collide between same-OS architectures
# (linux x86_64 vs arm64) in a flat dir. The binding's $ORIGIN/@loader_path rpath
# finds its siblings in the same dir.
[libraries]
linux.debug.x86_64 =     "res://addons/nobodywho/x86_64-unknown-linux-gnu/libnobodywho-godot-x86_64-unknown-linux-gnu-debug.so"
linux.release.x86_64 =   "res://addons/nobodywho/x86_64-unknown-linux-gnu/libnobodywho-godot-x86_64-unknown-linux-gnu-release.so"
linux.debug.arm64 =      "res://addons/nobodywho/aarch64-unknown-linux-gnu/libnobodywho-godot-aarch64-unknown-linux-gnu-debug.so"
linux.release.arm64 =    "res://addons/nobodywho/aarch64-unknown-linux-gnu/libnobodywho-godot-aarch64-unknown-linux-gnu-release.so"
windows.debug.x86_64 =   "res://addons/nobodywho/x86_64-pc-windows-msvc/libnobodywho-godot-x86_64-pc-windows-msvc-release.dll"
windows.release.x86_64 = "res://addons/nobodywho/x86_64-pc-windows-msvc/libnobodywho-godot-x86_64-pc-windows-msvc-release.dll"
macos.debug =            "res://addons/nobodywho/x86_64-apple-darwin/libnobodywho-godot-x86_64-apple-darwin-debug.dylib"
macos.release =          "res://addons/nobodywho/x86_64-apple-darwin/libnobodywho-godot-x86_64-apple-darwin-release.dylib"
macos.debug.arm64 =      "res://addons/nobodywho/aarch64-apple-darwin/libnobodywho-godot-aarch64-apple-darwin-debug.dylib"
macos.release.arm64 =    "res://addons/nobodywho/aarch64-apple-darwin/libnobodywho-godot-aarch64-apple-darwin-release.dylib"
android.debug.arm64 =      "res://addons/nobodywho/aarch64-linux-android/libnobodywho-godot-aarch64-linux-android-debug.so"
android.release.arm64 =    "res://addons/nobodywho/aarch64-linux-android/libnobodywho-godot-aarch64-linux-android-release.so"

# Dependencies Godot ships next to the binding on export; the empty destination
# string keeps each in the binding's directory (where its rpath expects it). The
# per-platform ggml set differs: macOS libggml-metal, Linux libggml-vulkan,
# Android CPU only (no Vulkan/Metal).
[dependencies]
linux.debug.x86_64 = { "res://addons/nobodywho/x86_64-unknown-linux-gnu/libggml.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libggml-base.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libggml-cpu.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libggml-vulkan.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libllama.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libllama-common.so": "" }
linux.release.x86_64 = { "res://addons/nobodywho/x86_64-unknown-linux-gnu/libggml.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libggml-base.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libggml-cpu.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libggml-vulkan.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libllama.so": "", "res://addons/nobodywho/x86_64-unknown-linux-gnu/libllama-common.so": "" }
linux.debug.arm64 = { "res://addons/nobodywho/aarch64-unknown-linux-gnu/libggml.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libggml-base.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libggml-cpu.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libggml-vulkan.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libllama.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libllama-common.so": "" }
linux.release.arm64 = { "res://addons/nobodywho/aarch64-unknown-linux-gnu/libggml.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libggml-base.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libggml-cpu.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libggml-vulkan.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libllama.so": "", "res://addons/nobodywho/aarch64-unknown-linux-gnu/libllama-common.so": "" }
windows.debug.x86_64 = { "res://addons/nobodywho/x86_64-pc-windows-msvc/ggml.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/ggml-base.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/ggml-cpu.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/ggml-vulkan.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/llama.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/llama-common.dll": "" }
windows.release.x86_64 = { "res://addons/nobodywho/x86_64-pc-windows-msvc/ggml.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/ggml-base.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/ggml-cpu.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/ggml-vulkan.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/llama.dll": "", "res://addons/nobodywho/x86_64-pc-windows-msvc/llama-common.dll": "" }
macos.debug = { "res://addons/nobodywho/x86_64-apple-darwin/libggml.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libggml-base.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libggml-cpu.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libggml-metal.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libllama.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libllama-common.dylib": "" }
macos.release = { "res://addons/nobodywho/x86_64-apple-darwin/libggml.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libggml-base.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libggml-cpu.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libggml-metal.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libllama.dylib": "", "res://addons/nobodywho/x86_64-apple-darwin/libllama-common.dylib": "" }
macos.debug.arm64 = { "res://addons/nobodywho/aarch64-apple-darwin/libggml.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libggml-base.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libggml-cpu.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libggml-metal.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libllama.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libllama-common.dylib": "" }
macos.release.arm64 = { "res://addons/nobodywho/aarch64-apple-darwin/libggml.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libggml-base.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libggml-cpu.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libggml-metal.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libllama.dylib": "", "res://addons/nobodywho/aarch64-apple-darwin/libllama-common.dylib": "" }
android.debug.arm64 = { "res://addons/nobodywho/aarch64-linux-android/libggml.so": "", "res://addons/nobodywho/aarch64-linux-android/libggml-base.so": "", "res://addons/nobodywho/aarch64-linux-android/libggml-cpu.so": "", "res://addons/nobodywho/aarch64-linux-android/libllama.so": "", "res://addons/nobodywho/aarch64-linux-android/libllama-common.so": "" }
android.release.arm64 = { "res://addons/nobodywho/aarch64-linux-android/libggml.so": "", "res://addons/nobodywho/aarch64-linux-android/libggml-base.so": "", "res://addons/nobodywho/aarch64-linux-android/libggml-cpu.so": "", "res://addons/nobodywho/aarch64-linux-android/libllama.so": "", "res://addons/nobodywho/aarch64-linux-android/libllama-common.so": "" }

[icons]
NobodyWhoModel =            "res://addons/nobodywho/icon.svg"
NobodyWhoChat =             "res://addons/nobodywho/icon.svg"
NobodyWhoEmbedding =             "res://addons/nobodywho/icon.svg"
NobodyWhoCrossEncoder =             "res://addons/nobodywho/icon.svg"
