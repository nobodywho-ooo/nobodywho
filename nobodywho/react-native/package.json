{
  "name": "react-native-nobodywho",
  "version": "0.1.2",
  "description": "Run LLMs locally with offline inference — React Native bindings",
  "main": "src/wrapper.ts",
  "types": "src/wrapper.ts",
  "exports": {
    ".": "./src/wrapper.ts"
  },
  "license": "EUPL-1.2",
  "homepage": "https://nobodywho.ooo",
  "bugs": "https://github.com/nobodywho-ooo/nobodywho/issues",
  "keywords": [
    "react-native",
    "ai",
    "llm",
    "local-ai",
    "inference",
    "gguf",
    "on-device",
    "offline"
  ],
  "files": [
    "src/",
    "generated/",
    "cpp/",
    "ios/",
    "android/",
    "Nobodywho.podspec",
    "ubrn.config.yaml",
    "!android/build",
    "!android/.cxx",
    "!android/src/main/jniLibs"
  ],
  "codegenConfig": {
    "name": "NobodywhoSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nobodywho-ooo/nobodywho"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "dependencies": {
    "uniffi-bindgen-react-native": "0.30.0-1"
  }
}
