{
  "name": "react-native-nobodywho",
  "version": "0.0.1",
  "description": "Run LLMs locally with offline inference — React Native bindings",
  "main": "src/wrapper.ts",
  "types": "src/wrapper.ts",
  "exports": {
    ".": "./src/wrapper.ts"
  },
  "license": "MIT",
  "files": [
    "src/",
    "generated/",
    "cpp/",
    "ios/",
    "android/",
    "Nobodywho.podspec",
    "NobodywhoFramework.xcframework",
    "ubrn.config.yaml",
    "!android/build"
  ],
  "codegenConfig": {
    "name": "NobodywhoSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nobodywho-ooo/nobodywho"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "uniffi-bindgen-react-native": "0.30.0-1"
  }
}
