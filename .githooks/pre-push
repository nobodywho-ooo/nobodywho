#!/bin/bash

recipes=(fmt clippy regen-python regen-flutter ruff regen-uniffi flutter-analyze godot-build)
pids=()
logs=()

for recipe in "${recipes[@]}"; do
    echo "⏳ $recipe"
    log=$(mktemp)
    logs+=("$log")
    just "$recipe" >"$log" 2>&1 &
    pids+=($!)
done

echo ""

failed=()
for i in "${!pids[@]}"; do
    if wait "${pids[$i]}"; then
        echo "✅ ${recipes[$i]}"
    else
        echo "❌ ${recipes[$i]}"
        failed+=("${recipes[$i]}")
    fi
done

for log in "${logs[@]}"; do
    rm -f "$log"
done

echo ""
if [ ${#failed[@]} -eq 0 ]; then
    echo "✅ all checks passed"
    exit 0
else
    echo "❌ failed: ${failed[*]}"
    echo ""
    echo "Run 'just <recipe>' to see the full output."
    exit 1
fi
